# Collei 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改配置值

# ═══════════════════════════════════════════════════════════════
# 应用配置
# ═══════════════════════════════════════════════════════════════

# 应用名称
COLLEI_APP_NAME=Collei

# 调试模式（启用 /docs 和 /redoc API 文档）
# 生产环境请设置为 false
COLLEI_DEBUG=true

# ═══════════════════════════════════════════════════════════════
# 数据库配置
# ═══════════════════════════════════════════════════════════════

# SQLite 数据库路径（默认相对于项目根目录）
# 支持绝对路径或相对路径
# COLLEI_DATABASE_URL=sqlite+aiosqlite:///collei.db

# PostgreSQL 示例（未来扩展）
# COLLEI_DATABASE_URL=postgresql+asyncpg://user:pass@localhost/collei

# ═══════════════════════════════════════════════════════════════
# 安全配置
# ═══════════════════════════════════════════════════════════════

# JWT 签名密钥 — ⚠️ 生产环境必须修改为随机强密钥 ⚠️
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(64))"
COLLEI_SECRET_KEY=change-me-to-a-random-secret-key-in-production

# JWT 签名算法
COLLEI_ALGORITHM=HS256

# Access Token 有效期（分钟）
COLLEI_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 会话有效期（天）
COLLEI_SESSION_EXPIRE_DAYS=7

# ═══════════════════════════════════════════════════════════════
# 防暴力破解配置
# ═══════════════════════════════════════════════════════════════

# 同一 IP 在窗口期内最大登录失败次数
COLLEI_LOGIN_ATTEMPT_LIMIT=10

# 登录失败统计窗口期（秒）
COLLEI_LOGIN_ATTEMPT_WINDOW=600

# 两阶段登录 challenge 有效期（秒）
COLLEI_LOGIN_2FA_CHALLENGE_EXPIRE_SECONDS=300

# ═══════════════════════════════════════════════════════════════
# 初始管理员账号（仅首次启动时使用）
# ═══════════════════════════════════════════════════════════════

# 默认管理员用户名
COLLEI_DEFAULT_ADMIN_USERNAME=admin

# 默认管理员密码 — ⚠️ 首次启动必须设置 ⚠️
# 留空则不自动创建管理员账号
COLLEI_DEFAULT_ADMIN_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# 生产环境推荐配置
# ═══════════════════════════════════════════════════════════════

# 1. 关闭调试模式
#    COLLEI_DEBUG=false

# 2. 使用强随机密钥
#    COLLEI_SECRET_KEY=<生成的随机密钥>

# 3. 合理设置 Token 有效期（根据安全需求平衡）
#    COLLEI_ACCESS_TOKEN_EXPIRE_MINUTES=60
#    COLLEI_SESSION_EXPIRE_DAYS=1

# 4. 首次启动后立即修改管理员密码并清空此环境变量
